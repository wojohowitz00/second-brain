# Second Brain System - Environment Variables
# Copy this file to .env and fill in your values
# Source with: source .env

# Slack Bot Token (starts with xoxb-)
# Get from: https://api.slack.com/apps > Your App > OAuth & Permissions
export SLACK_BOT_TOKEN="xoxb-your-bot-token-here"

# Slack App-Level Token (starts with xapp-) - Required for real-time Socket Mode
# Get from: https://api.slack.com/apps > Your App > Basic Information > App-Level Tokens
# Create one with scope: connections:write
export SLACK_APP_TOKEN="xapp-your-app-token-here"

# Slack Channel ID for #wry_sb
# Right-click channel > View channel details > scroll to bottom for ID
export SLACK_CHANNEL_ID="C0123456789"

# Your Slack User ID (for DM alerts)
# Click your profile > ... > Copy member ID
export SLACK_USER_ID="U0123456789"
